import { defineConfig } from 'vite';
import react from '@vitejs/plugin-react';
import { OpenAI } from 'openai';
import dotenv from 'dotenv';

// Load environment variables
dotenv.config();

// Create mock OpenAI client if API key is missing
const OPENAI_API_KEY = process.env.OPENAI_API_KEY;
let openai;

if (!OPENAI_API_KEY || OPENAI_API_KEY === 'your-openai-api-key') {
  console.warn('Missing OPENAI_API_KEY environment variable. Using mock OpenAI client.');
  
  // Create a mock OpenAI client
  openai = {
    chat: {
      completions: {
        create: async () => {
          return {
            choices: [
              {
                message: {
                  content: JSON.stringify({
                    name: "Sample Item",
                    description: "This is a sample item description generated because no OpenAI API key was provided.",
                    tags: ["sample", "mock", "demo"]
                  })
                }
              }
            ]
          };
        }
      }
    }
  };
} else {
  // Create real OpenAI client with timeout configuration
  // We've already checked OPENAI_API_KEY is not null/undefined above,
  // but TypeScript doesn't track this, so we need an explicit check
  const apiKey = OPENAI_API_KEY || ''; // Convert possible null/undefined to empty string
  
  openai = new OpenAI({
    apiKey, // Now TypeScript knows this is a string
    timeout: 60000,
    maxRetries: 3
  });
}

export default defineConfig({
  plugins: [
    react(),
    {
      name: 'image-analysis-server',
      configureServer(server) {
        server.middlewares.use('/api/analyze-image', async (req, res) => {
          if (req.method === 'POST') {
            // Set a longer timeout for the request
            req.setTimeout(60000);
            
            // Set a timeout for the entire request processing
            const timeoutId = setTimeout(() => {
              if (!res.writableEnded) {
                res.statusCode = 504;
                res.end(JSON.stringify({ error: 'Request timed out' }));
              }
            }, 65000); // Slightly longer than the OpenAI timeout
            
            let body = '';
            req.on('data', chunk => {
              body += chunk;
            });
            
            req.on('end', async () => {
              clearTimeout(timeoutId); // Clear timeout when request is done
              
              try {
                const { imageUrl } = JSON.parse(body);
                
                // Validate URL
                if (!imageUrl || typeof imageUrl !== 'string') {
                  throw new Error('Invalid image URL provided');
                }

                // Decode the URL if it's encoded
                const decodedUrl = decodeURIComponent(imageUrl);

                let analysis;
                
                if (!OPENAI_API_KEY || OPENAI_API_KEY === 'your-openai-api-key') {
                  // Use mock data if no API key
                  analysis = {
                    name: "Sample Item",
                    description: "This is a sample item description generated because no OpenAI API key was provided.",
                    tags: ["sample", "mock", "demo"]
                  };
                } else {
                  // Use real OpenAI API
                  try {
                    const response = await openai.chat.completions.create({
                      model: "gpt-4o-mini",
                      messages: [
                        {
                          role: "user",
                          content: [
                            { 
                              type: "text", 
                              text: "Describe this found item in JSON format with fields: name (short title), description (characteristics and condition), tags (2-3 keywords)" 
                            },
                            {
                              type: "image_url",
                              image_url: {
                                url: decodedUrl
                              }
                            }
                          ]
                        }
                      ],
                      max_tokens: 500,
                      response_format: { type: "json_object" }
                    });
                    
                    try {
                      analysis = JSON.parse(response.choices[0].message.content);
                    } catch (parseError) {
                      console.error('Error parsing OpenAI response:', parseError);
                      analysis = { name: "", description: "", tags: [] };
                    }
                  } catch (openaiError) {
                    console.error('OpenAI API error:', openaiError);
                    throw openaiError; // Re-throw to be handled by outer catch
                  }
                }
                
                // Ensure the response matches the expected format
                const formattedAnalysis = {
                  name: analysis.name || '',
                  description: analysis.description || '',
                  tags: Array.isArray(analysis.tags) ? analysis.tags : []
                };
                
                res.setHeader('Content-Type', 'application/json');
                res.end(JSON.stringify(formattedAnalysis));
              } catch (error: any) { // Type annotation for error
                console.error('Error analyzing image:', error);
                
                // Determine appropriate error message
                let errorMessage = 'Failed to analyze image';
                let statusCode = 500;
                
                if (error && (error.code === 'ECONNRESET' || error.type === 'system')) {
                  errorMessage = 'Connection error. Please try again.';
                } else if (error && error.status === 429) {
                  errorMessage = 'Too many requests. Please try again later.';
                  statusCode = 429;
                }
                
                res.statusCode = statusCode;
                res.end(JSON.stringify({ 
                  error: errorMessage,
                  details: error.message 
                }));
              }
            });
          } else {
            res.statusCode = 405;
            res.end('Method not allowed');
          }
        });
      }
    }
  ],
  optimizeDeps: {
    exclude: ['lucide-react'],
  }
});

